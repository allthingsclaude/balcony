#!/bin/bash
# Balcony Hook Handler
#
# Reads Claude Code hook JSON from stdin and sends it to
# BalconyMac's hook listener via Unix domain socket.
#
# Usage in ~/.claude/settings.json:
#   {
#     "hooks": {
#       "PermissionRequest": [{
#         "type": "command",
#         "command": "~/.balcony/hook-handler",
#         "async": true
#       }]
#     }
#   }
#
# Install:
#   cp Scripts/hook-handler ~/.balcony/hook-handler
#   chmod +x ~/.balcony/hook-handler

SOCKET_PATH="$HOME/.balcony/hooks.sock"

# Check if the socket exists
if [ ! -S "$SOCKET_PATH" ]; then
    exit 0
fi

# Read stdin and forward to the Unix socket.
# Use socat if available (more reliable), fall back to Python.
if command -v socat &>/dev/null; then
    cat | socat - UNIX-CONNECT:"$SOCKET_PATH" 2>/dev/null
elif command -v python3 &>/dev/null; then
    python3 -c "
import socket, sys
data = sys.stdin.buffer.read()
if data:
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        s.connect('$SOCKET_PATH')
        s.sendall(data)
    except:
        pass
    finally:
        s.close()
"
else
    # Last resort: use /dev/tcp if available (bash only, not zsh)
    exit 0
fi
